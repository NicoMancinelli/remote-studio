{
    "layout": {
        "type": "layout",
        "pages": ["page_session", "page_panel", "page_behavior"],
        "page_session": {
            "type": "page",
            "title": "Session",
            "sections": ["section_profile", "section_auto"]
        },
        "page_panel": {
            "type": "page",
            "title": "Panel",
            "sections": ["section_panel"]
        },
        "page_behavior": {
            "type": "page",
            "title": "Behavior",
            "sections": ["section_behavior"]
        },
        "section_profile": {
            "type": "section",
            "title": "Default Profile",
            "keys": ["default_profile"]
        },
        "section_auto": {
            "type": "section",
            "title": "Auto Session",
            "keys": ["auto_session", "auto_session_profile"]
        },
        "section_panel": {
            "type": "section",
            "title": "Panel Label",
            "keys": ["label_color_enabled", "uptime_display", "show_latency_bars"]
        },
        "section_behavior": {
            "type": "section",
            "title": "Behavior",
            "keys": ["notify_enabled", "middle_click_action", "confirm_destructive", "dbus_reconnect"]
        }
    },
    "default_profile": {
        "type": "combobox",
        "default": "mac",
        "description": "Default Session Profile (quick-start button)",
        "options": {
            "Mac (2560x1664)": "mac",
            "Mac 15\" (2880x1864)": "mac15",
            "iPad Pro 13\" (2064x2752)": "ipad13",
            "iPad Pro 11\" (1668x2388)": "ipad",
            "iPhone Portrait (1170x2532)": "iphonep",
            "iPhone Landscape (2532x1170)": "iphonel",
            "Standard Reset (1024x768)": "fallback",
            "Last Used Profile": "last"
        }
    },
    "auto_session": {
        "type": "checkbox",
        "default": false,
        "description": "Automatically start session when a remote connection is detected"
    },
    "auto_session_profile": {
        "type": "combobox",
        "default": "last",
        "description": "Profile to auto-start (or 'Last Used')",
        "dependency": "auto_session",
        "options": {
            "Last Used Profile": "last",
            "Mac (2560x1664)": "mac",
            "Mac 15\" (2880x1864)": "mac15",
            "iPad Pro 13\" (2064x2752)": "ipad13",
            "iPad Pro 11\" (1668x2388)": "ipad",
            "iPhone Portrait (1170x2532)": "iphonep",
            "iPhone Landscape (2532x1170)": "iphonel",
            "Standard Reset (1024x768)": "fallback"
        }
    },
    "notify_enabled": {
        "type": "checkbox",
        "default": true,
        "description": "Enable connect/disconnect desktop notifications"
    },
    "label_color_enabled": {
        "type": "checkbox",
        "default": true,
        "description": "Color-code the panel label by connection state"
    },
    "uptime_display": {
        "type": "checkbox",
        "default": true,
        "description": "Show session uptime in the panel label"
    },
    "show_latency_bars": {
        "type": "checkbox",
        "default": true,
        "description": "Show latency quality indicator (bars) in the tooltip"
    },
    "middle_click_action": {
        "type": "combobox",
        "default": "menu",
        "description": "Action on middle-click of the panel icon",
        "options": {
            "Open Menu (default)": "menu",
            "Toggle Speed Mode": "speed",
            "Toggle Night Shift": "night",
            "Start/Stop Session": "session",
            "Privacy Shield": "privacy",
            "Copy Direct Address": "copy"
        }
    },
    "dbus_reconnect": {
        "type": "checkbox",
        "default": true,
        "description": "Auto-reconnect to DBus daemon if it restarts"
    },
    "confirm_destructive": {
        "type": "checkbox",
        "default": true,
        "description": "Require confirmation before Stop Session and Reset"
    }
}