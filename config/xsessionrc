#!/bin/bash
# Restore the last known Remote Studio display state at login.

# Disable overlay scrollbars for remote sessions
export GTK_OVERLAY_SCROLLING=0

STATE_FILE="$HOME/.res_state"

if [ -f "$STATE_FILE" ]; then
    # Last field is the quoted label; captured as remainder but not needed here
    read -r width height scaling text_scale cursor _ < "$STATE_FILE"

    OUTPUT=$(xrandr 2>/dev/null | grep " connected" | head -n 1 | cut -f1 -d" ")
    if [ -n "$OUTPUT" ]; then
        MODE_NAME="remote-studio-${width}x${height}-60"
        MODE_INFO=$(cvt "$width" "$height" 60 2>/dev/null | grep Modeline)

        if [ -n "$MODE_INFO" ] && ! xrandr 2>/dev/null | grep -q "$MODE_NAME"; then
            MODE_PARAMS=$(printf '%s' "$MODE_INFO" | cut -d' ' -f3-)
            # shellcheck disable=SC2086
            xrandr --newmode "$MODE_NAME" $MODE_PARAMS 2>/dev/null || true
        fi
        xrandr --addmode "$OUTPUT" "$MODE_NAME" 2>/dev/null || true
        xrandr --output "$OUTPUT" --mode "$MODE_NAME" 2>/dev/null || true

        gsettings set org.cinnamon.desktop.interface scaling-factor "$scaling" 2>/dev/null || true
        gsettings set org.cinnamon.desktop.interface text-scaling-factor "$text_scale" 2>/dev/null || true
        gsettings set org.cinnamon.desktop.interface cursor-size "$cursor" 2>/dev/null || true

        dpi=$(awk "BEGIN { printf \"%d\", 96 * $scaling }")
        echo "Xft.dpi: $dpi" | xrdb -merge 2>/dev/null || true
    fi
fi
